{
  "name": "telemetry-engine",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p packages/engine/tsconfig.json && tsc --noEmit -p packages/transport/tsconfig.json && tsc --noEmit -p packages/transport-webrtc/tsconfig.json && tsc --noEmit -p packages/ui-shared/tsconfig.json && tsc --noEmit -p packages/ui-phone/tsconfig.json",
    "lint:content": "node packages/content-lint/bin/lint-content.mjs",
    "sim:smoke": "node packages/sim/bin/sim.mjs --campaigns 50",
    "sim:full": "node packages/sim/bin/sim.mjs --campaigns 1000",
    "build:stub": "node scripts/build-stub.mjs",
    "build:pages": "pnpm --filter @telemetry/ui-shared build",
    "demo:m0": "pnpm --filter @telemetry/ui-shared exec vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test:e2e": "node scripts/pages-smoke.mjs",
    "dev:shared": "pnpm --filter @telemetry/ui-shared dev",
    "dev:phone": "pnpm --filter @telemetry/ui-phone dev"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "fast-check": "^3.23.1",
    "jsdom": "^25.0.1",
    "playwright-core": "^1.61.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
