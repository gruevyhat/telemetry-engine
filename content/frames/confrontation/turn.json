{
  "frame": "confrontation",
  "start": "declare",
  "steps": [
    { "id": "declare", "kind": "confrontation", "render": "confrontation.declare", "timer": 300, "next": "resolution-choice" },
    {
      "id": "resolution-choice",
      "kind": "branch",
      "next": {
        "accuse": "accusation-vote",
        "search": "search",
        "let-lie": "let-lie",
        "replace-captain": "captain-vote",
        "put-off-ship": "removal-vote",
        "timer-expired": "captain-decision"
      }
    },
    { "id": "accusation-vote", "kind": "vote", "render": "confrontation.vote", "next": { "carried": "forced-burn", "failed": "resolution" } },
    { "id": "forced-burn", "kind": "confrontation", "render": "confrontation.forced-burn", "automatic": true, "next": "deferred-reveal" },
    { "id": "deferred-reveal", "kind": "confrontation", "render": "confrontation.deferred-reveal", "automatic": true, "next": "resolution" },
    { "id": "search", "kind": "confrontation", "render": "confrontation.search", "next": "resolution" },
    { "id": "let-lie", "kind": "confrontation", "render": "confrontation.let-lie", "next": "resolution" },
    { "id": "captain-vote", "kind": "vote", "render": "confrontation.captain-vote", "next": { "carried": "captain-replaced", "failed": "resolution" } },
    { "id": "captain-replaced", "kind": "confrontation", "render": "confrontation.captain-replaced", "automatic": true, "next": "resolution" },
    { "id": "removal-vote", "kind": "vote", "render": "confrontation.removal-vote", "next": { "carried": "crew-removed", "failed": "resolution" } },
    { "id": "crew-removed", "kind": "confrontation", "render": "confrontation.crew-removed", "automatic": true, "next": "resolution" },
    { "id": "captain-decision", "kind": "branch", "next": { "search": "search", "let-lie": "let-lie" } },
    { "id": "resolution", "kind": "confrontation", "render": "confrontation.resolution", "automatic": true, "next": "declare" }
  ]
}
