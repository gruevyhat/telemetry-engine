{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["frame", "start", "steps"],
  "properties": {
    "frame": { "type": "string", "minLength": 1 },
    "start": { "type": "string", "minLength": 1 },
    "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/step" } }
  },
  "$defs": {
    "visibility": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["level"], "properties": { "level": { "enum": ["public", "table", "referee"] } } },
        { "type": "object", "additionalProperties": false, "required": ["level", "playerIds"], "properties": { "level": { "const": "private" }, "playerIds": { "type": "array", "items": { "type": "string" }, "minItems": 1 } } }
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": { "kind": { "enum": ["pc", "npc", "world", "referee"] }, "id": { "type": "string", "minLength": 1 } }
    },
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "actor", "payload"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "actor": { "$ref": "#/$defs/actor" },
        "payload": { "type": "object" },
        "visibility": { "$ref": "#/$defs/visibility" },
        "causes": { "type": "array", "items": { "type": "string" } },
        "frame": { "type": "string" }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "next"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["announce", "generate", "check", "vote", "commsWindow", "confrontation", "branch", "tickClock"] },
        "render": { "type": "string", "minLength": 1 },
        "slot": { "enum": ["DOCKSIDE", "COMMS", "TRANSIT", "ARRIVAL", "DOWNTIME"] },
        "automatic": { "type": "boolean" },
        "facts": { "type": "array", "items": { "$ref": "#/$defs/fact" } },
        "timer": { "type": "number", "minimum": 0 },
        "visibility": { "$ref": "#/$defs/visibility" },
        "next": { "oneOf": [{ "type": "string", "minLength": 1 }, { "type": "object", "additionalProperties": { "type": "string", "minLength": 1 }, "minProperties": 1 }] },
        "check": { "type": "object", "additionalProperties": false, "required": ["skillSlot", "difficulty", "onFail", "onSuccess"], "properties": { "skillSlot": { "type": "string" }, "difficulty": { "type": "number" }, "onFail": { "type": "string" }, "onSuccess": { "type": "string" } } },
        "tick": { "type": "object", "additionalProperties": false, "required": ["clockId", "delta"], "properties": { "clockId": { "type": "string" }, "delta": { "type": "number" } } }
      }
    }
  }
}
